<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Better Me LLC</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Italiana&family=Tenor+Sans&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}

/* ══ SITE NAV ══ */
.site-nav{
  position:fixed;top:0;left:0;right:0;z-index:9999;
  background:rgba(250,246,240,0.95);backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(180,140,120,0.18);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 52px;height:70px;
}
.site-nav-brand{display:flex;flex-direction:column;line-height:1.2;}
.site-nav-brand-main{font-family:'Playfair Display',serif;font-size:1.2rem;letter-spacing:0.1em;color:#2e1f14;}
.site-nav-brand-main em{font-style:italic;color:#c89888;}
.site-nav-brand-sub{font-family:'DM Sans',sans-serif;font-size:0.52rem;letter-spacing:0.28em;text-transform:uppercase;color:rgba(100,70,55,0.45);}
.site-nav-links{display:flex;gap:32px;list-style:none;}
.site-nav-links a{font-family:'DM Sans',sans-serif;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(46,31,20,0.55);text-decoration:none;transition:color 0.2s;}
.site-nav-links a:hover{color:#c89888;}
.site-nav-cta{font-family:'DM Sans',sans-serif;background:#2e1f14;color:#faf6f0;padding:10px 26px;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:background 0.25s;}
.site-nav-cta:hover{background:#c89888;}

/* ══ HERO ══ */
.site-hero{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  padding-top:70px;position:relative;overflow:hidden;
  background:linear-gradient(160deg,#faf6f0 0%,#f5ece4 45%,#ede0d4 100%);
}
.site-hero-ring{position:absolute;border-radius:50%;border:1px solid rgba(180,140,120,0.25);pointer-events:none;}
.site-hero-petal{position:absolute;border-radius:50% 50% 50% 0;pointer-events:none;opacity:0.22;}
@keyframes sitePetalFloat{0%,100%{transform:translateY(0) rotate(var(--r,0deg));}50%{transform:translateY(-14px) rotate(var(--r,0deg));}}
.site-hero-inner{text-align:center;max-width:700px;padding:0 32px;position:relative;z-index:1;animation:siteHeroUp 1s ease both;}
@keyframes siteHeroUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
.site-hero-kicker{font-family:'DM Sans',sans-serif;font-size:0.68rem;letter-spacing:0.35em;text-transform:uppercase;color:#c89888;margin-bottom:28px;display:flex;align-items:center;justify-content:center;gap:16px;}
.site-hero-kicker span.ln{width:40px;height:1px;background:#c89888;display:inline-block;}
.site-hero-h1{font-family:'Playfair Display',serif;font-size:clamp(3.5rem,8vw,6.5rem);line-height:1;color:#2e1f14;margin-bottom:6px;font-weight:400;}
.site-hero-h1 em{font-style:italic;color:#c89888;}
.site-hero-llc{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-style:italic;color:rgba(46,31,20,0.4);margin-bottom:32px;letter-spacing:0.1em;}
.site-hero-desc{font-family:'Cormorant Garamond',serif;font-size:1.1rem;line-height:1.85;color:rgba(46,31,20,0.6);font-weight:300;max-width:520px;margin:0 auto 48px;}
.site-hero-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}
.sbtn-dark{background:#2e1f14;color:#faf6f0;padding:16px 40px;font-family:'DM Sans',sans-serif;font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all 0.3s;display:inline-block;}
.sbtn-dark:hover{background:#c89888;transform:translateY(-2px);}
.sbtn-outline{background:transparent;color:#2e1f14;padding:16px 40px;font-family:'DM Sans',sans-serif;font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;border-radius:2px;border:1px solid rgba(46,31,20,0.22);transition:all 0.3s;display:inline-block;}
.sbtn-outline:hover{border-color:#c89888;color:#c89888;}

/* ══ SITE MARQUEE ══ */
.site-marquee{background:#2e1f14;padding:14px 0;overflow:hidden;}
.site-marquee-track{display:flex;animation:siteMarquee 24s linear infinite;width:max-content;}
@keyframes siteMarquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}
.site-marquee-item{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.9rem;color:rgba(250,246,240,0.6);padding:0 40px;white-space:nowrap;display:flex;align-items:center;gap:16px;}
.site-marquee-item::after{content:'◆';font-size:0.4rem;color:#c89888;font-style:normal;}

/* ══ PRODUCT DIVIDER ══ */
.product-divider{
  display:flex;align-items:center;justify-content:center;gap:24px;
  padding:60px 52px 20px;
}
.product-divider-line{flex:1;height:1px;background:rgba(46,31,20,0.1);}
.product-divider-label{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,2.5vw,2rem);color:#2e1f14;font-weight:400;letter-spacing:0.08em;text-align:center;white-space:nowrap;}
.product-divider-label em{font-style:italic;color:#c89888;}
.product-divider-label.green em{color:#3d5c40;}
.product-divider-sub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.95rem;color:rgba(46,31,20,0.45);text-align:center;padding:0 52px 48px;}

/* ══ PRICE BAR ══ */
.price-bar{
  background:#faf6f0;
  border-top:1px solid rgba(46,31,20,0.07);
  border-bottom:1px solid rgba(46,31,20,0.07);
  padding:32px 80px;
  display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap;
}
.price-bar.dark{background:#2e1f14;}
.price-bar.green{background:#f0f7f0;}
.price-bar-left{
  flex:1 1 320px;
  min-width:280px;
}
.price-bar-label{font-family:'DM Sans',sans-serif;font-size:0.65rem;letter-spacing:0.28em;text-transform:uppercase;margin-bottom:4px;}
.price-bar.dark .price-bar-label{color:rgba(250,246,240,0.4);}
.price-bar.green .price-bar-label{color:rgba(61,92,64,0.5);}
.price-bar:not(.dark):not(.green) .price-bar-label{color:rgba(46,31,20,0.45);}
.price-bar-amount{font-family:'Playfair Display',serif;font-size:3rem;line-height:1;letter-spacing:0.02em;}
.price-bar.dark .price-bar-amount{color:#b8973a;}
.price-bar.green .price-bar-amount{color:#3d5c40;}
.price-bar:not(.dark):not(.green) .price-bar-amount{color:#c89888;}
.price-bar-size{font-family:'DM Sans',sans-serif;font-size:0.72rem;letter-spacing:0.1em;margin-left:10px;vertical-align:middle;}
.price-bar.dark .price-bar-size{color:rgba(250,246,240,0.35);}
.price-bar.green .price-bar-size{color:rgba(61,92,64,0.4);}
.price-bar:not(.dark):not(.green) .price-bar-size{color:rgba(46,31,20,0.35);}
.price-bar-note{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.9rem;margin-top:4px;}
.price-bar.dark .price-bar-note{color:rgba(250,246,240,0.3);}
.price-bar.green .price-bar-note{color:rgba(61,92,64,0.4);}
.price-bar:not(.dark):not(.green) .price-bar-note{color:rgba(46,31,20,0.35);}
.price-bar-ing{
  flex:1 1 320px;
  min-width:280px;
}
.price-bar-ing-title{font-family:'DM Sans',sans-serif;font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:10px;}
.price-bar.dark .price-bar-ing-title{color:rgba(250,246,240,0.35);}
.price-bar.green .price-bar-ing-title{color:rgba(61,92,64,0.45);}
.price-bar:not(.dark):not(.green) .price-bar-ing-title{color:rgba(46,31,20,0.4);}
.price-bar-ing-list{display:flex;flex-wrap:wrap;gap:8px;}
.price-bar-ing-pill{font-family:'Cormorant Garamond',serif;font-size:0.88rem;padding:4px 14px;border-radius:40px;}
.price-bar.dark .price-bar-ing-pill{background:rgba(255,255,255,0.07);color:rgba(250,246,240,0.65);border:1px solid rgba(255,255,255,0.1);}
.price-bar.green .price-bar-ing-pill{background:rgba(61,92,64,0.08);color:rgba(61,92,64,0.7);border:1px solid rgba(61,92,64,0.15);}
.price-bar:not(.dark):not(.green) .price-bar-ing-pill{background:rgba(200,152,136,0.08);color:rgba(46,31,20,0.65);border:1px solid rgba(200,152,136,0.18);}
.price-bar-btns{display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-start;align-items:center;}
.pb-btn-main{padding:14px 32px;font-family:'DM Sans',sans-serif;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;border:none;border-radius:2px;cursor:pointer;color:white;transition:all 0.25s;}
.pb-btn-main.gold{background:#b8973a;} .pb-btn-main.gold:hover{background:#8a7030;}
.pb-btn-main.plum{background:#9060a8;} .pb-btn-main.plum:hover{background:#6a4088;}
.pb-btn-main.sage{background:#3d5c40;} .pb-btn-main.sage:hover{background:#2a4a2d;}
.pb-btn-main.rose{background:#c89888;} .pb-btn-main.rose:hover{background:#a07868;}
.pb-btn-sec{padding:14px 24px;font-family:'DM Sans',sans-serif;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;border-radius:2px;cursor:pointer;background:transparent;transition:all 0.2s;}
.price-bar.dark .pb-btn-sec{color:rgba(250,246,240,0.55);border:1px solid rgba(255,255,255,0.15);}
.price-bar.dark .pb-btn-sec:hover{border-color:#b8973a;color:#b8973a;}
.price-bar.green .pb-btn-sec{color:rgba(61,92,64,0.6);border:1px solid rgba(61,92,64,0.2);}
.price-bar.green .pb-btn-sec:hover{border-color:#3d5c40;color:#3d5c40;}
.price-bar:not(.dark):not(.green) .pb-btn-sec{color:rgba(46,31,20,0.55);border:1px solid rgba(46,31,20,0.18);}
.price-bar:not(.dark):not(.green) .pb-btn-sec:hover{border-color:#c89888;color:#c89888;}

/* ══ ABOUT & FOOTER ══ */
.site-ethos{background:#2e1f14;padding:72px 52px;display:grid;grid-template-columns:repeat(3,1fr);}
.site-ethos-item{padding:36px;text-align:center;border-right:1px solid rgba(255,255,255,0.07);}
.site-ethos-item:last-child{border-right:none;}
.site-ethos-icon{font-size:1.8rem;margin-bottom:16px;}
.site-ethos-title{font-family:'Playfair Display',serif;font-size:1.1rem;color:#faf6f0;font-weight:400;margin-bottom:10px;letter-spacing:0.06em;}
.site-ethos-body{font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:rgba(250,246,240,0.45);line-height:1.75;}

.site-about{padding:90px 52px;max-width:900px;margin:0 auto;text-align:center;background:#faf6f0;}
.site-about-tag{display:inline-block;background:#f5ece4;color:#c89888;font-family:'DM Sans',sans-serif;font-size:0.62rem;letter-spacing:0.25em;text-transform:uppercase;padding:8px 20px;border-radius:40px;margin-bottom:24px;}
.site-about-title{font-family:'Playfair Display',serif;font-size:clamp(1.7rem,3vw,2.7rem);color:#2e1f14;font-weight:400;margin-bottom:24px;line-height:1.3;}
.site-about-title em{font-style:italic;color:#c89888;}
.site-about-body{font-family:'Cormorant Garamond',serif;font-size:1.05rem;line-height:1.9;color:rgba(46,31,20,0.6);max-width:660px;margin:0 auto 18px;}

.site-footer{background:#1a1008;padding:52px 52px 28px;display:flex;flex-direction:column;align-items:center;gap:24px;}
.site-footer-brand{font-family:'Playfair Display',serif;font-size:1.3rem;color:#faf6f0;letter-spacing:0.1em;text-align:center;}
.site-footer-brand em{font-style:italic;color:#c89888;}
.site-footer-sub{font-family:'DM Sans',sans-serif;font-size:0.52rem;letter-spacing:0.28em;text-transform:uppercase;color:rgba(250,246,240,0.25);margin-top:4px;}
.site-footer-links{display:flex;gap:24px;flex-wrap:wrap;justify-content:center;}
.site-footer-links a{font-family:'DM Sans',sans-serif;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(250,246,240,0.28);text-decoration:none;transition:color 0.2s;}
.site-footer-links a:hover{color:#c89888;}
.site-footer-copy{font-family:'DM Sans',sans-serif;font-size:0.6rem;color:rgba(250,246,240,0.15);letter-spacing:0.08em;text-align:center;border-top:1px solid rgba(255,255,255,0.05);padding-top:20px;width:100%;max-width:800px;}

/* ══ GOAT AD STYLES (scoped via .goat-ad) ══ */
.goat-ad{
  --ivory:#faf6f0;--parchment:#f0e8d8;--stone:#d4c5b0;--taupe:#8c7b6b;
  --espresso:#2e1f14;--gold:#b8973a;--gold-lt:#d4b96a;--sage-g:#7a8c6e;
  --cream-dk:#c4a882;--blush:#e8d5c4;
  font-family:'Tenor Sans',sans-serif;
  background:var(--ivory);color:var(--espresso);overflow-x:hidden;
}
.goat-ad .hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;position:relative;overflow:hidden;}
.goat-ad .hero::after{content:'';position:absolute;top:0;bottom:0;left:50%;width:2px;background:linear-gradient(to bottom,transparent,var(--stone) 30%,var(--stone) 70%,transparent);transform:rotate(3deg) translateX(-50%);z-index:2;}
.goat-ad .hero-left{display:flex;flex-direction:column;justify-content:center;padding:80px 70px 80px 80px;position:relative;z-index:3;}
.goat-ad .kicker{font-size:0.68rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--gold);margin-bottom:32px;display:flex;align-items:center;gap:16px;}
.goat-ad .kicker::before,.goat-ad .kicker::after{content:'';flex:0 0 30px;height:1px;background:var(--gold);}
.goat-ad .hero-title{font-family:'Italiana',serif;font-size:clamp(4rem,7vw,7.5rem);line-height:0.95;color:var(--espresso);margin-bottom:12px;letter-spacing:0.04em;}
.goat-ad .hero-title .goat{display:block;color:var(--gold);font-size:clamp(5rem,9vw,9.5rem);line-height:0.9;}
.goat-ad .hero-subtitle-line{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.3rem;color:var(--taupe);margin-bottom:48px;letter-spacing:0.04em;}
.goat-ad .hero-desc{font-size:0.92rem;line-height:1.85;color:var(--taupe);max-width:380px;margin-bottom:52px;font-weight:300;letter-spacing:0.02em;}
.goat-ad .hero-actions{display:flex;align-items:center;gap:32px;}
.goat-ad .btn-gold{display:inline-block;background:var(--gold);color:var(--ivory);padding:16px 40px;font-size:0.72rem;letter-spacing:0.22em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all 0.3s ease;}
.goat-ad .btn-gold:hover{background:var(--espresso);transform:translateY(-2px);}
.goat-ad .btn-ghost{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;color:var(--taupe);text-decoration:none;border-bottom:1px solid var(--stone);padding-bottom:2px;transition:all 0.2s;}
.goat-ad .btn-ghost:hover{color:var(--gold);border-color:var(--gold);}
.goat-ad .hero-right{position:relative;display:flex;align-items:center;justify-content:center;background:linear-gradient(145deg,var(--parchment) 0%,var(--blush) 60%,var(--stone) 100%);overflow:hidden;z-index:1;}
.goat-ad .bg-circle{position:absolute;border-radius:50%;}
.goat-ad .bg-circle-1{width:500px;height:500px;background:radial-gradient(circle,rgba(184,151,58,0.12) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);}
.goat-ad .bg-circle-2{width:300px;height:300px;background:radial-gradient(circle,rgba(255,255,255,0.4) 0%,transparent 70%);top:10%;right:10%;animation:gPulse 6s ease-in-out infinite;}
.goat-ad .arc{position:absolute;border-radius:50%;border:1px solid rgba(184,151,58,0.2);}
.goat-ad .arc-1{width:400px;height:400px;top:50%;left:50%;transform:translate(-50%,-50%);}
.goat-ad .arc-2{width:550px;height:550px;top:50%;left:50%;transform:translate(-50%,-50%);}
.goat-ad .arc-3{width:700px;height:700px;top:50%;left:50%;transform:translate(-50%,-50%);}
.goat-ad .product-stage{position:relative;z-index:5;display:flex;flex-direction:column;align-items:center;gap:28px;animation:gFloat 7s ease-in-out infinite;}
.goat-ad .jar-wrap{filter:drop-shadow(0 30px 60px rgba(46,31,20,0.22));}
.goat-ad .jar-wrap svg{width:220px;height:auto;}
.goat-ad .float-tag{position:absolute;background:white;border-radius:4px;padding:10px 18px;font-size:0.72rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--espresso);box-shadow:0 8px 30px rgba(0,0,0,0.1);display:flex;align-items:center;gap:8px;white-space:nowrap;}
.goat-ad .float-tag .pip{width:6px;height:6px;border-radius:50%;background:var(--gold);}
.goat-ad .float-tag-1{top:20%;left:-30px;animation:gFloatTag 5s ease-in-out infinite;}
.goat-ad .float-tag-2{bottom:28%;right:-20px;animation:gFloatTag 6s 1.5s ease-in-out infinite reverse;}
.goat-ad .rating-badge{background:var(--espresso);color:var(--ivory);border-radius:4px;padding:14px 24px;display:flex;align-items:center;gap:14px;}
.goat-ad .rating-stars{color:var(--gold);letter-spacing:3px;font-size:0.9rem;}
.goat-ad .rating-text{font-size:0.72rem;letter-spacing:0.1em;opacity:0.7;text-transform:uppercase;}
.goat-ad .marquee-wrap{background:var(--espresso);padding:20px 0;overflow:hidden;}
.goat-ad .marquee-track{display:flex;animation:gMarquee 20s linear infinite;width:max-content;}
.goat-ad .marquee-item{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;color:rgba(250,246,240,0.7);padding:0 40px;white-space:nowrap;display:flex;align-items:center;gap:16px;}
.goat-ad .marquee-item::after{content:'◆';font-size:0.4rem;color:var(--gold);font-style:normal;}
.goat-ad .philosophy{display:grid;grid-template-columns:1fr 1fr;min-height:80vh;}
.goat-ad .philosophy-left{background:var(--espresso);padding:100px 80px;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;}
.goat-ad .philosophy-left::before{content:'G.O.A.T.';position:absolute;font-family:'Italiana',serif;font-size:12rem;color:rgba(255,255,255,0.03);bottom:-20px;right:-20px;line-height:1;pointer-events:none;}
.goat-ad .phil-eyebrow{font-size:0.65rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:28px;}
.goat-ad .phil-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.5vw,3.2rem);color:var(--ivory);line-height:1.2;margin-bottom:28px;}
.goat-ad .phil-title em{font-style:italic;color:var(--gold-lt);}
.goat-ad .phil-body{font-size:0.9rem;line-height:1.9;color:rgba(250,246,240,0.6);max-width:400px;margin-bottom:48px;}
.goat-ad .phil-stats{display:grid;grid-template-columns:1fr 1fr;gap:32px;border-top:1px solid rgba(255,255,255,0.08);padding-top:40px;}
.goat-ad .stat-num{font-family:'Italiana',serif;font-size:2.8rem;color:var(--gold);line-height:1;margin-bottom:6px;}
.goat-ad .stat-label{font-size:0.72rem;letter-spacing:0.16em;text-transform:uppercase;color:rgba(250,246,240,0.45);}
.goat-ad .philosophy-right{background:var(--parchment);padding:100px 80px;display:flex;flex-direction:column;justify-content:center;}
.goat-ad .how-title{font-family:'Italiana',serif;font-size:2rem;color:var(--espresso);margin-bottom:48px;letter-spacing:0.06em;}
.goat-ad .steps{display:flex;flex-direction:column;gap:0;}
.goat-ad .step{display:flex;gap:28px;padding:28px 0;border-bottom:1px solid var(--stone);}
.goat-ad .step:first-child{padding-top:0;} .goat-ad .step:last-child{border-bottom:none;}
.goat-ad .step-num{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-style:italic;color:var(--stone);line-height:1;min-width:36px;}
.goat-ad .step-title{font-size:0.78rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--espresso);margin-bottom:8px;}
.goat-ad .step-desc{font-size:0.88rem;line-height:1.7;color:var(--taupe);}
.goat-ad .ingredients{padding:110px 80px;background:var(--ivory);}
.goat-ad .section-head{text-align:center;margin-bottom:72px;}
